# Fastfile for Android deployment

default_platform(:android)

platform :android do
  desc "Deploy AAB to Google Play Internal Track"
  lane :deploy_internal do |options|
    aab_path = options[:aab_path] || "../build/app/outputs/bundle/release/app-release.aab"
    version = options[:version]

    upload_to_play_store(
      aab: aab_path,
      track: 'internal',
      version_name: version,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: 'completed'
    )
  end

  desc "Promote internal-track AAB to Production, pushing metadata + screenshots. Defaults to draft status (operator manually sends for review); set submit_for_review:true to release status 'completed' (auto-sent for review — Managed Publishing in Play Console then gates post-review publish on a manual click)."
  lane :promote_to_production_draft do |options|
    version = options[:version]
    version_code = options[:version_code]
    # Fastlane CLI args arrive as strings; coerce to a real boolean.
    submit_for_review = options[:submit_for_review].to_s == "true"

    UI.user_error!("version is required") unless version
    UI.user_error!("version_code is required") unless version_code

    # Play requires changelogs/<versionCode>.txt for every release. Generate
    # it from the canonical template — release notes rarely vary per build,
    # so we keep one source of truth and stamp each versionCode at deploy time.
    # Fastlane chdirs into fastlane/ before lane execution, so resolve from
    # there; expand to absolute so supply isn't sensitive to any later chdir.
    metadata_dir = File.expand_path("metadata/android")
    template = File.join(metadata_dir, "en-US/default_release_notes.txt")
    changelog_dir = File.join(metadata_dir, "en-US/changelogs")
    changelog = File.join(changelog_dir, "#{version_code}.txt")
    UI.user_error!("Missing #{template}") unless File.exist?(template)
    FileUtils.mkdir_p(changelog_dir)
    FileUtils.cp(template, changelog)

    upload_to_play_store(
      metadata_path: metadata_dir,
      track: 'internal',
      track_promote_to: 'production',
      # 'completed' = auto-submit for review (Managed Publishing then holds
      # the approved release for manual publish). 'draft' = release sits in
      # Play Console awaiting manual 'Send for review' click.
      track_promote_release_status: submit_for_review ? 'completed' : 'draft',
      version_name: version,
      version_code: version_code.to_i,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )

    if submit_for_review
      UI.success("Promoted #{version} (#{version_code}) to Production with release status 'completed'. Google's review is async; once approved Play will hold the release for a manual 'Publish' click in Play Console (Managed Publishing).")
    else
      UI.success("Promoted #{version} (#{version_code}) to Production as a draft. Click 'Send for review' in Play Console when ready.")
    end
  end
end
