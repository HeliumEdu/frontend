    "react-dom": "^15.6.1",
    "react-redux": "^5.0.5",
    "react-router-dom": "^4.1.2",
    "redux": "^3.7.2",
    "redux-form": "^7.0.3",
    "redux-thunk": "^2.2.0",
    "universal-cookie": "^2.0.8",
    "webpack": "^3.3.0",
    "webpack-dev-server": "^2.5.1"
