# Fastfile for iOS deployment

default_platform(:ios)

platform :ios do
  desc "Print the next available build number for a given version"
  lane :next_build_number do |options|
    version = options[:version]
    UI.user_error!("version is required") unless version

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    current = latest_testflight_build_number(
      api_key: api_key,
      version: version,
      initial_build_number: 0
    )

    next_number = current + 1
    UI.message("Next build number for #{version}: #{next_number}")
    next_number
  end

  desc "Upload IPA to TestFlight and wait for App-Store-side processing"
  lane :deploy_testflight do |options|
    ipa_path = options[:ipa_path] || "../build/ios/ipa/heliumedu.ipa"

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    # Wait for processing so deploy_appstore can attach the build immediately
    # in the same pipeline run.
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      wait_processing_timeout_duration: 1800,
      distribute_external: false
    )
  end

  desc "Stage an App Store version with the latest TestFlight build, push metadata text every time and screenshots only when push_store_assets:true. Optionally auto-submit for App Review (post-review publish remains manual via App Store Connect). The marketing app icon is part of the IPA and is not affected by this flag."
  lane :deploy_appstore do |options|
    version = options[:version]
    build_number = options[:build_number]
    # Fastlane CLI args arrive as strings; coerce to a real boolean.
    submit_for_review = options[:submit_for_review].to_s == "true"
    # Default false: screenshots only re-upload when the operator explicitly
    # flips this on. Re-pushing identical bytes still flips the asset records
    # in App Store Connect and forces Apple to re-review marketing assets.
    push_store_assets = options[:push_store_assets].to_s == "true"

    UI.user_error!("version is required") unless version
    UI.user_error!("build_number is required") unless build_number

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    # If the target App Store version is past the editable stage (submitted,
    # in review, live, etc.), fail the lane rather than letting
    # `upload_to_app_store` partially mutate an in-flight submission. The
    # TestFlight upload above already succeeded; the operator must resolve
    # the existing submission in App Store Connect (or, if the version is
    # already shipped, do a patch bump) before re-running.
    locked_states = %w[
      READY_FOR_REVIEW
      WAITING_FOR_REVIEW
      IN_REVIEW
      PROCESSING_FOR_APP_STORE
      PENDING_APPLE_RELEASE
      PENDING_DEVELOPER_RELEASE
      READY_FOR_SALE
      REPLACED_WITH_NEW_VERSION
    ]
    app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    spaceship_app = Spaceship::ConnectAPI::App.find(app_identifier)
    existing = spaceship_app.get_app_store_versions(filter: { versionString: version }).first
    if existing && locked_states.include?(existing.app_store_state)
      UI.user_error!(
        "App Store version #{version} is in state " \
        "`#{existing.app_store_state}` — cannot stage. TestFlight upload " \
        "above succeeded; do a patch bump (if the version is shipped) or " \
        "resolve the in-flight submission in App Store Connect, then re-run."
      )
    end

    upload_to_app_store(
      api_key: api_key,
      app_version: version,
      build_number: build_number,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: !push_store_assets,
      # Without this, deliver appends to existing slots instead of replacing
      # the set, so order in App Store Connect drifts from local filename order.
      overwrite_screenshots: true,
      submit_for_review: submit_for_review,
      # `automatic_release: false` is the post-review manual-publish gate —
      # Apple's equivalent of Play's Managed Publishing, applied per-version.
      # The version sits in PENDING_DEVELOPER_RELEASE after Apple approves
      # until the operator clicks "Release this version" in App Store Connect.
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )

    if submit_for_review
      # When submitting for review, deliver itself locates and attaches the
      # build as part of the submission flow — no manual selection needed.
      UI.success("Submitted App Store version #{version} (build #{build_number}) for review. Apple's review is async; when approved the version will sit in PENDING_DEVELOPER_RELEASE awaiting a manual 'Release this version' click in App Store Connect.")
      next
    end

    # `upload_to_app_store` only auto-selects a TestFlight build when
    # `submit_for_review: true`. We deliberately stop short of submit, so
    # deliver leaves the App Store version unattached. Select the build
    # explicitly so the version lands fully staged — operator only has to
    # click Submit for Review.
    #
    # Note: Spaceship's Build.all keyword names are counter-intuitive — the
    # `version:` keyword filters by `preReleaseVersion.version` (the SEMVER),
    # and the `build_number:` keyword filters by the Build's own `version`
    # field (the CFBundleVersion). See spaceship/connect_api/models/build.rb.
    edit_version = spaceship_app.get_edit_app_store_version(platform: "IOS")
    UI.user_error!("No editable App Store version found for #{version} after upload_to_app_store") unless edit_version

    build = Spaceship::ConnectAPI::Build.all(
      app_id: spaceship_app.id,
      version: version,
      build_number: build_number,
      limit: 1
    ).first
    UI.user_error!("TestFlight build #{version} (#{build_number}) not found in App Store Connect — TestFlight processing may not have completed.") unless build

    edit_version.select_build(build_id: build.id)
    UI.success("Attached build #{version} (#{build_number}) to App Store version #{version}")
  end
end
