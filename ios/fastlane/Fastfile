# Fastfile for iOS deployment

default_platform(:ios)

platform :ios do
  desc "Upload IPA to TestFlight and wait for App-Store-side processing"
  lane :deploy_testflight do |options|
    ipa_path = options[:ipa_path] || "../build/ios/ipa/heliumedu.ipa"

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    # Wait for processing so deploy_appstore can attach the build immediately
    # in the same pipeline run.
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      wait_processing_timeout_duration: 1800,
      distribute_external: false
    )
  end

  desc "Stage an App Store version with the latest TestFlight build, push metadata + screenshots, stop short of Submit for Review"
  lane :deploy_appstore do |options|
    version = options[:version]
    build_number = options[:build_number]

    UI.user_error!("version is required") unless version
    UI.user_error!("build_number is required") unless build_number

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    upload_to_app_store(
      api_key: api_key,
      app_version: version,
      build_number: build_number,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
