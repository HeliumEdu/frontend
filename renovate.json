{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "ignoreDeps": ["dart", "test_api"],
  "timezone": "America/Chicago",
  "schedule": ["at any time"],
  "enabledManagers": ["pub"],
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchDepTypes": ["dev_dependencies"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["^firebase_"],
      "groupName": "firebase"
    },
    {
      "matchPackagePatterns": ["^syncfusion_"],
      "groupName": "syncfusion"
    },
    {
      "matchManagers": ["pub"],
      "automerge": true
    }
  ]
}
